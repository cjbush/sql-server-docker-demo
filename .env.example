# Copy this file to .env and fill in the values.
# The .env file is intentionally excluded from source control.

# Required: SA (system administrator) password.
# Must be at least 8 characters and contain uppercase, lowercase,
# digits, and a special character (SQL Server strong-password policy).
SA_PASSWORD=YourStrong!Passw0rd

# Optional: SQL Server edition (Developer, Express, Standard, Enterprise).
# Defaults to Developer (free, full-featured, for non-production use).
MSSQL_PID=Developer

# Optional: host port to publish SQL Server on. Defaults to 1433.
HOST_PORT=1433
